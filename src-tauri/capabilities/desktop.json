{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "desktop",
  "description": "Desktop-only permissions: window control, native file dialogs, in-app updater",
  "platforms": ["linux", "macOS", "windows"],
  "windows": ["main"],
  "permissions": [
    "core:window:allow-set-title",
    "core:window:allow-destroy",
    "dialog:allow-open",
    "dialog:allow-save",
    "updater:default",
    "process:default"
  ]
}
