{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Termkin",
  "version": "0.4.2",
  "identifier": "com.codework.vaulterm",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Termkin",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 26
    },
    "iOS": {
      "minimumSystemVersion": "14.0"
    },
    "windows": {
      "nsis": {
        "installerHooks": "./installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Temkung007/Vaulterm/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg3REJBQTlGNjU1OTM1QgpSV1JiazFYMnFicDlDTG1iYmUzdjY2aFM3SnRNeU8wWGJiSEpOaVFCSlNTL1NIUWxpQjQyR1dKeQo="
    }
  }
}
